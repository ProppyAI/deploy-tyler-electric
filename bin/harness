cmd_metric() {
  local subcmd="${1:-help}"
  shift 2>/dev/null || true

  case "$subcmd" in
    draft)
      # The skill drives the actual draft; this command is a no-op stub for parity.
      # Future: could log the draft event to session.notify.
      echo "metric draft is driven by the harness:define-metric skill; no-op here"
      ;;
    approve)
      if [[ $# -lt 1 ]]; then
        echo "Usage: harness metric approve <session_id>" >&2
        exit 1
      fi
      harness_metric_approve "$1"
      ;;
    reject)
      if [[ $# -lt 1 ]]; then
        echo "Usage: harness metric reject <session_id> --reason \"<text>\"" >&2
        exit 1
      fi
      local session_id="$1"
      shift
      local reason=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --reason)
            if [[ $# -lt 2 ]]; then
              echo "ERROR: --reason requires a value" >&2
              exit 1
            fi
            reason="$2"
            shift 2
            ;;
          *) shift ;;
        esac
      done
      [[ -n "$reason" ]] || { echo "HARNESS: --reason required" >&2; exit 1; }
      harness_metric_reject "$session_id" "$reason"
      ;;
    verify)
      if [[ $# -lt 1 ]]; then
        echo "Usage: harness metric verify <session_id>" >&2
        exit 1
      fi
      harness_metric_verify "$1"
      ;;
    help|*)
      cat <<METRICEOF
Usage:
  harness metric draft <session_id>                    Stub (skill-driven)
  harness metric approve <session_id>                  Lock the metric, sha-pin, advance chain
  harness metric reject <session_id> --reason "text"   Reject and set status=needs-human
  harness metric verify <session_id>                   Sha-check the pinned metric file
  harness metric help                                  Show this message
METRICEOF
      ;;
  esac
}

